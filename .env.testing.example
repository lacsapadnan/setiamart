# Copy to ".env.testing" and adjust values (see Laravel testing docs + Context7 / Laravel 12.x "Environment").
# Laravel loads this file instead of .env when APP_ENV=testing (PHPUnit / Pest / artisan --env=testing).
#
# --- Agar data development tidak ikut ter-reset ---
# 1) Buat database MySQL KHUSUS testing, misalnya: CREATE DATABASE pos_testing;
# 2) Isi DB_DATABASE di bawah dengan nama itu — JANGAN pakai nama DB yang sama dengan kerjaan harian.
# 3) Trait RefreshDatabase di tes akan migrate ulang / transaksi hanya ke DB testing itu.
#
# Referensi: https://laravel.com/docs/12.x/testing (The .env.testing Environment File)

APP_NAME="POS Testing"
APP_ENV=testing
APP_KEY=base64:0HEeQnXsQizJS7/r8bon17mR4N5bj6tZIk1ONxiP01E=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_testing
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array

TELESCOPE_ENABLED=false
